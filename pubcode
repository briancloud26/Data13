  <script src="/_sdk/editing_sdk.js"></script>
  <script>
    const steps = [
      {
        prompt: "Hi, I was charged twice for my subscription this month and I'm really frustrated. I need this fixed today.",
        choices: [
          "I understand this is frustrating, and I’m sorry for the trouble. Let me review the billing activity and get this sorted for you.",
          "That usually happens when there are two accounts. Did you maybe sign up twice?",
          "I can help with that. Please hold while I check your account."
        ],
        correct: 0,
        score: 25,
        note: "Excellent opening. You acknowledged the emotion and took ownership before moving into action.",
        scoreCopy: "Strong start — empathy and ownership are both present.",
        skill: "empathy"
      },
      {
        prompt: "Okay, thanks. I just don’t want to have to call back again about this.",
        choices: [
          "I completely understand. To make sure I resolve this properly, I’m going to confirm the last four digits of the payment method and review both charges with you.",
          "You shouldn't have to call again if billing fixes it.",
          "No problem, I’ll just refund one of them right away."
        ],
        correct: 0,
        score: 25,
        note: "Nice clarification. You reassured the customer while explaining exactly what you need next.",
        scoreCopy: "You’re building confidence by making the process clear.",
        skill: "clarity"
      },
      {
        prompt: "The last four digits are 4821. Can you see what happened?",
        choices: [
          "Yes, I can see the duplicate renewal. I’m submitting the refund now, and it should return to your card within 3–5 business days.",
          "Yes, there are two charges here.",
          "Looks like a duplicate. You’ll probably see a refund soon."
        ],
        correct: 0,
        score: 25,
        note: "Great solution language. You named the issue, explained the action, and set a realistic expectation.",
        scoreCopy: "Clear next steps help the customer feel taken care of.",
        skill: "solution"
      },
      {
        prompt: "Alright, that helps. Is there anything else I need to do?",
        choices: [
          "You’re all set. I’ve also added a note to your account, and I’ll send a confirmation email shortly so you have this in writing.",
          "No, that's it.",
          "Just keep an eye on your statement and call us if it doesn’t show up."
        ],
        correct: 0,
        score: 25,
        note: "Strong close. You reduced future effort and ended with confidence.",
        scoreCopy: "That was a polished, reassuring close.",
        skill: "close"
      }
    ];

    let current = 0;
    let totalScore = 0;
    let answered = false;
    const completedSkills = new Set();

    const promptEl = document.getElementById('customer-prompt');
    const choicesEl = document.getElementById('choices');
    const nextButton = document.getElementById('next-button');
    const feedbackState = document.getElementById('feedback-state');
    const coachNote = document.getElementById('coach-note');
    const scoreValue = document.getElementById('score-value');
    const scoreRing = document.getElementById('score-ring');
    const scoreCopy = document.getElementById('score-copy');
    const progressFill = document.getElementById('progress-fill');
    const progressLabel = document.getElementById('progress-label');
    const stepCurrent = document.getElementById('step-current');

    function renderStep(){
      answered = false;
      const step = steps[current];
      promptEl.textContent = step.prompt;
      choicesEl.innerHTML = '';
      step.choices.forEach((choice, index) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'choice-card focus-ring w-full text-left rounded-2xl p-4 sm:p-5 flex gap-4 items-start';
        button.innerHTML = `
          <span class="shrink-0 w-7 h-7 rounded-full border border-white/10 grid place-items-center text-xs text-[#9fe3c7]">${String.fromCharCode(65 + index)}</span>
          <span class="text-[#e5eceb] leading-6">${choice}</span>
        `;
        button.addEventListener('click', () => selectChoice(index, button));
        choicesEl.appendChild(button);
      });
      stepCurrent.textContent = String(current + 1);
      const pct = ((current + 1) / steps.length) * 100;
      progressFill.style.width = pct + '%';
      progressLabel.textContent = Math.round(pct) + '%';
      feedbackState.textContent = 'Choose the best response';
      nextButton.disabled = true;
      nextButton.classList.add('opacity-50','cursor-not-allowed');
      nextButton.classList.remove('hover:bg-[#b7efd8]');
      if(current === steps.length - 1){
        nextButton.querySelector('span').textContent = 'See results';
      } else {
        nextButton.querySelector('span').textContent = 'Next prompt';
      }
    }

    function selectChoice(index, button){
      if(answered) return;
      answered = true;
      const step = steps[current];
      const all = [...choicesEl.children];
      all.forEach((el, i) => {
        el.disabled = true;
        if(i === step.correct) el.classList.add('correct');
      });
      button.classList.add(index === step.correct ? 'selected' : 'incorrect');

      const isCorrect = index === step.correct;
      if(isCorrect){
        totalScore += step.score;
        completedSkills.add(step.skill);
        feedbackState.textContent = 'Strong response';
        coachNote.textContent = step.note;
        scoreCopy.textContent = step.scoreCopy;
        updateSkill(step.skill, true);
      } else {
        feedbackState.textContent = 'Good try — review the stronger option';
        coachNote.textContent = "Look for the response that combines empathy, clarity, and a confident next step.";
        scoreCopy.textContent = "You’re still building the habit — notice how the best response reduces customer effort.";
        updateSkill(step.skill, false);
      }
      updateScore();
      nextButton.disabled = false;
      nextButton.classList.remove('opacity-50','cursor-not-allowed');
      nextButton.classList.add('hover:bg-[#b7efd8]');
    }

    function updateScore(){
      scoreValue.textContent = totalScore;
      const deg = totalScore * 3.6;
      scoreRing.style.background = `conic-gradient(var(--mint) ${deg}deg, rgba(255,255,255,.08) ${deg}deg)`;
    }

    function updateSkill(skill, success){
      const status = document.getElementById(`skill-${skill}`);
      const icon = document.getElementById(`skill-${skill}-icon`);
      status.textContent = success ? 'Complete' : 'Practice';
      status.className = success ? 'text-xs text-[#9fe3c7]' : 'text-xs text-[#f2bf72]';
      icon.className = success
        ? 'w-7 h-7 rounded-full border border-[#9fe3c7]/40 bg-[#9fe3c7]/10 grid place-items-center text-[#9fe3c7]'
        : 'w-7 h-7 rounded-full border border-[#f2bf72]/40 bg-[#f2bf72]/10 grid place-items-center text-[#f2bf72]';
    }

    nextButton.addEventListener('click', () => {
      if(!answered) return;
      if(current < steps.length - 1){
        current++;
        renderStep();
      } else {
        showComplete();
      }
    });

    function showComplete(){
      document.getElementById('practice-view').classList.add('hidden');
      document.getElementById('complete-view').classList.remove('hidden');
      document.getElementById('final-score').textContent = totalScore + '%';
      document.getElementById('final-strength').textContent = totalScore >= 75 ? 'Customer reassurance' : 'Empathy opener';
      document.getElementById('final-focus').textContent = totalScore >= 75 ? 'Consistency under pressure' : 'Clear next steps';
      document.getElementById('final-note').textContent =
        totalScore >= 75
          ? 'You delivered a confident support experience. Keep this same calm, specific tone when the customer is more emotional or the issue is less clear.'
          : 'You have a solid foundation. On your next round, focus on pairing empathy with a specific action so the customer always knows what happens next.';
    }

    document.getElementById('restart-button').addEventListener('click', () => {
      current = 0;
      totalScore = 0;
      completedSkills.clear();
      ['empathy','clarity','solution','close'].forEach(skill => {
        const status = document.getElementById(`skill-${skill}`);
        const icon = document.getElementById(`skill-${skill}-icon`);
        status.textContent = 'Pending';
        status.className = 'text-xs text-[#7f8fa2]';
        icon.className = 'w-7 h-7 rounded-full border border-white/10 grid place-items-center text-[#7c8b9f]';
      });
      scoreCopy.textContent = 'Start strong by listening for the customer\\'s main concern.';
      coachNote.textContent = 'Your coach will give instant feedback after each response.';
      updateScore();
      document.getElementById('complete-view').classList.add('hidden');
      document.getElementById('practice-view').classList.remove('hidden');
      renderStep();
    });

    renderStep();
    lucide.createIcons();
  </script>
