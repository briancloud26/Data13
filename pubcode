<!doctype html>
<html lang="en"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CallCraft Practice</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&amp;family=Fraunces:opsz,wght@9..144,600;9..144,700&amp;display=swap" rel="stylesheet">
  <style>
    :root{
      --ink:#0d1726;
      --panel:#122033;
      --panel-2:#18283c;
      --line:rgba(255,255,255,.11);
      --muted:#93a1b3;
      --cream:#f5efe4;
      --mint:#9fe3c7;
      --mint-strong:#75d5af;
      --amber:#f2bf72;
      --rose:#f08b86;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:'DM Sans', sans-serif;
      color:var(--cream);
      min-height:100%;
    }
    .app-shell{
      width:100%;
      min-height:calc(100 * min(var(--vh, 1vh), 1vh));
      background:
        radial-gradient(circle at top left, rgba(67,119,112,.28), transparent 28%),
        radial-gradient(circle at bottom right, rgba(32,68,105,.32), transparent 30%),
        #0c1624;
      position:relative;
      overflow:hidden;
    }
    .app-shell:before{
      content:"";
      position:absolute;
      inset:0;
      background-image:linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
      background-size:42px 42px;
      opacity:.45;
      pointer-events:none;
    }
    .glass{
      background:linear-gradient(180deg, rgba(255,255,255,.055), rgba(255,255,255,.025));
      border:1px solid var(--line);
      box-shadow:0 24px 60px rgba(0,0,0,.22);
      backdrop-filter:blur(18px);
    }
    .serif{font-family:'Fraunces', serif}
    .choice-card{
      transition:.25s ease;
      border:1px solid rgba(255,255,255,.09);
      background:rgba(255,255,255,.035);
    }
    .choice-card:hover{
      transform:translateY(-2px);
      border-color:rgba(159,227,199,.55);
      background:rgba(159,227,199,.06);
    }
    .choice-card.selected{
      border-color:var(--mint);
      background:rgba(159,227,199,.11);
      box-shadow:0 0 0 1px rgba(159,227,199,.2) inset;
    }
    .choice-card.incorrect{
      border-color:rgba(240,139,134,.75);
      background:rgba(240,139,134,.09);
    }
    .choice-card.correct{
      border-color:rgba(159,227,199,.9);
      background:rgba(159,227,199,.12);
    }
    .progress-fill{transition:width .35s ease}
    .score-ring{
      background:conic-gradient(var(--mint) 0deg, var(--mint) 0deg, rgba(255,255,255,.08) 0deg);
      transition:background .35s ease;
    }
    .fade-in{animation:fadeIn .45s ease both}
    @keyframes fadeIn{from{opacity:0; transform:translateY(10px)}to{opacity:1; transform:translateY(0)}}
    .pulse-dot{animation:pulse 1.8s infinite}
    @keyframes pulse{0%,100%{opacity:.45}50%{opacity:1}}
    .focus-ring:focus-visible{outline:2px solid var(--mint); outline-offset:3px}
    @media (max-width: 1024px){
      .main-grid{grid-template-columns:1fr}
    }
  </style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 </head>
 <body data-template-id="__page-root" style="background: rgb(12, 22, 36);">
  <div class="app-shell">
   <div class="relative z-10 w-full max-w-7xl mx-auto px-5 sm:px-8 py-6 sm:py-8">
