    .soft-shadow { box-shadow: var(--shadow); }

    .image-shade::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(18,15,12,.04), rgba(18,15,12,.38));
      pointer-events: none;
    }

    .card-image::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 48%, rgba(36,29,22,.16));
      pointer-events: none;
    }

    .rise {
      opacity: 0;
      transform: translateY(16px);
      animation: rise .8s ease forwards;
    }

    .delay-1 { animation-delay: .08s; }
    .delay-2 { animation-delay: .18s; }
    .delay-3 { animation-delay: .28s; }
    .delay-4 { animation-delay: .38s; }

    @keyframes rise {
      to { opacity: 1; transform: translateY(0); }
    }

    .collectible {
      transition: transform .28s ease, box-shadow .28s ease;
    }

    .collectible:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 36px rgba(83, 63, 41, .12);
    }
