<!doctype html>
<html lang="en"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SQL Code Generator</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <style>
        body { font-family: 'Space Mono', monospace; }
        .sql-output { white-space: pre-wrap; word-break: break-all; }
    </style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 </head>
 <body data-template-id="__page-root" class="min-h-screen" style="background: rgb(15, 23, 42);">
  <main class="w-full max-w-3xl mx-auto p-6">
   <header class="mb-8">
    <h1 data-template-id="page-title" class="canva-text text-2xl font-bold mb-2" style="color: rgb(74, 222, 128); font-weight: 700; font-style: normal; font-size: 28px;">SQL Code Generator</h1>
    <p data-template-id="page-subtitle" class="canva-text opacity-70" style="color: rgb(148, 163, 184); font-weight: 400; font-style: normal; font-size: 14px;">Build SQL queries visually — select a statement type and fill in the fields.</p>
   </header>
   <form id="sql-form" class="space-y-4">
    <div><label data-template-id="label-type" for="query-type" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">Query Type</label> <select id="query-type" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500"> <option value="SELECT">SELECT</option> <option value="INSERT">INSERT</option> <option value="UPDATE">UPDATE</option> <option value="DELETE">DELETE</option> </select>
    </div>
    <div><label data-template-id="label-table" for="table-name" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">Table Name</label> <input id="table-name" type="text" placeholder="e.g. users" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500">
    </div>
    <div id="columns-group"><label data-template-id="label-columns" for="columns" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">Columns</label> <input id="columns" type="text" placeholder="e.g. id, name, email  (or * for all)" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500">
    </div>
    <div id="values-group" class="hidden"><label data-template-id="label-values" for="values" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">Values</label> <input id="values" type="text" placeholder="e.g. 'John', 'john@email.com'" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500">
    </div>
    <div id="set-group" class="hidden"><label data-template-id="label-set" for="set-clause" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">SET Clause</label> <input id="set-clause" type="text" placeholder="e.g. name = 'Jane', active = true" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500">
    </div>
    <div id="where-group"><label data-template-id="label-where" for="where-clause" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">WHERE Clause</label> <input id="where-clause" type="text" placeholder="e.g. id = 1 AND active = true" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500">
    </div>
    <div id="orderby-group"><label data-template-id="label-orderby" for="order-by" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">ORDER BY</label> <input id="order-by" type="text" placeholder="e.g. name ASC" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500">
    </div>
    <div id="limit-group"><label data-template-id="label-limit" for="limit-val" class="canva-text block mb-1 font-bold" style="color: rgb(226, 232, 240); font-weight: 400; font-style: normal; font-size: 14px;">LIMIT</label> <input id="limit-val" type="number" placeholder="e.g. 10" class="w-full p-2 rounded border border-gray-600 bg-gray-800 text-green-300 focus:outline-none focus:ring-2 focus:ring-green-500">
    </div><button data-template-id="generate-btn" type="submit" class="canva-button w-full py-3 rounded font-bold transition hover:opacity-90" style="background: rgb(22, 163, 74); color: rgb(255, 255, 255); font-weight: 700; font-style: normal; font-size: 14px;">Generate SQL</button>
   </form>
   <div id="output-section" class="mt-8 hidden">
    <div class="flex items-center justify-between mb-2">
     <h2 data-template-id="output-title" class="canva-text font-bold" style="color: rgb(74, 222, 128); font-weight: 400; font-style: normal; font-size: 21px;">Generated SQL</h2><button id="copy-btn" class="flex items-center gap-1 px-3 py-1 rounded bg-gray-700 text-green-300 hover:bg-gray-600 transition text-sm"> <i data-lucide="copy" style="width:14px;height:14px;"></i> Copy </button>
    </div>
    <div data-template-id="output-box" class="canva-panel p-4 rounded-lg overflow-x-auto" style="background: rgb(30, 41, 59);"><code id="sql-output" class="sql-output text-green-300 text-sm"></code>
    </div>
   </div>
  </main>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
        lucide.createIcons();

        const form = document.getElementById('sql-form');
        const queryType = document.getElementById('query-type');

        function toggleFields() {
            const type = queryType.value;
            document.getElementById('columns-group').classList.toggle('hidden', type === 'DELETE');
            document.getElementById('values-group').classList.toggle('hidden', type !== 'INSERT');
            document.getElementById('set-group').classList.toggle('hidden', type !== 'UPDATE');
            document.getElementById('where-group').classList.toggle('hidden', type === 'INSERT');
            document.getElementById('orderby-group').classList.toggle('hidden', type !== 'SELECT');
            document.getElementById('limit-group').classList.toggle('hidden', type !== 'SELECT');
        }

        queryType.addEventListener('change', toggleFields);
        toggleFields();

        form.addEventListener('submit', function(e) {
            e.preventDefault();
            const type = queryType.value;
            const table = document.getElementById('table-name').value.trim() || 'table_name';
            const columns = document.getElementById('columns').value.trim() || '*';
            const values = document.getElementById('values').value.trim();
            const setClause = document.getElementById('set-clause').value.trim();
            const where = document.getElementById('where-clause').value.trim();
            const orderBy = document.getElementById('order-by').value.trim();
            const limit = document.getElementById('limit-val').value.trim();

            let sql = '';

            if (type === 'SELECT') {
                sql = `SELECT ${columns}\nFROM ${table}`;
                if (where) sql += `\nWHERE ${where}`;
                if (orderBy) sql += `\nORDER BY ${orderBy}`;
                if (limit) sql += `\nLIMIT ${limit}`;
            } else if (type === 'INSERT') {
                sql = `INSERT INTO ${table} (${columns})\nVALUES (${values || '...'})`;
            } else if (type === 'UPDATE') {
                sql = `UPDATE ${table}\nSET ${setClause || '...'}`;
                if (where) sql += `\nWHERE ${where}`;
            } else if (type === 'DELETE') {
                sql = `DELETE FROM ${table}`;
                if (where) sql += `\nWHERE ${where}`;
            }

            sql += ';';

            document.getElementById('sql-output').textContent = sql;
            document.getElementById('output-section').classList.remove('hidden');
        });

        document.getElementById('copy-btn').addEventListener('click', function() {
            const text = document.getElementById('sql-output').textContent;
            navigator.clipboard.writeText(text).then(() => {
                this.innerHTML = '<i data-lucide="check" style="width:14px;height:14px;"></i> Copied!';
                lucide.createIcons();
                setTimeout(() => {
                    this.innerHTML = '<i data-lucide="copy" style="width:14px;height:14px;"></i> Copy';
                    lucide.createIcons();
                }, 2000);
            });
        });
    </script>
