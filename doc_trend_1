    .glass-line {
      border: 1px solid rgba(109, 77, 50, 0.15);
      box-shadow: var(--shadow);
    }

    .hero-img-wrap::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(45,38,31,0.02), rgba(45,38,31,0.24));
      pointer-events: none;
    }

    .card-image-wrap::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 45%, rgba(35, 28, 22, 0.16));
      pointer-events: none;
    }

    .collectible-card {
      transition: transform .28s ease, box-shadow .28s ease;
    }

    .collectible-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 38px rgba(83, 63, 41, .12);
    }

    .fade-up {
      opacity: 0;
      transform: translateY(12px);
      animation: fadeUp .7s ease forwards;
    }

    .fade-up:nth-child(1) { animation-delay: .05s; }
    .fade-up:nth-child(2) { animation-delay: .12s; }
    .fade-up:nth-child(3) { animation-delay: .19s; }
    .fade-up:nth-child(4) { animation-delay: .26s; }
    .fade-up:nth-child(5) { animation-delay: .33s; }
    .fade-up:nth-child(6) { animation-delay: .40s; }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }
