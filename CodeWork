  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&amp;family=Source+Serif+Pro:wght@600;700&amp;display=swap" rel="stylesheet">
  <style>
    :root{
      --ink:#1f2c27;
      --muted:#718077;
      --line:#dfe6df;
      --soft:#f6f6f2;
      --panel:#fbfbf7;
      --accent:#315f4c;
      --accent-dark:#244839;
      --accent-soft:#eaf1ec;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:'Raleway',sans-serif;
      color:var(--ink);
      background:var(--soft);
    }
    .page-shell{
      width:100%;
      min-height:calc(100 * min(var(--vh, 1vh), 1vh));
      overflow:hidden;
    }
    .serif{font-family:'Source Serif Pro',serif}
    .focus-ring:focus-visible{
      outline:3px solid rgba(49,95,76,.22);
      outline-offset:3px;
    }
    .hero-grid{
      display:grid;
      grid-template-columns:minmax(0,1.02fr) minmax(360px,.98fr);
      gap:4rem;
      align-items:center;
    }
    .image-frame{
      position:relative;
      isolation:isolate;
    }
    .image-frame::before{
      content:"";
      position:absolute;
      inset:auto auto -24px -24px;
      width:78%;
      height:74%;
      background:#dce8df;
      z-index:-1;
    }
    .image-frame::after{
      content:"";
      position:absolute;
      top:-18px;
      right:-18px;
      width:84px;
      height:84px;
      border-top:1px solid #a9b9ae;
      border-right:1px solid #a9b9ae;
      z-index:-1;
    }
    .feature-card{
      transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }
    .feature-card:hover{
      transform:translateY(-4px);
      border-color:#cbd8cf;
      box-shadow:0 14px 28px rgba(31,44,39,.06);
    }
    .reveal{
      opacity:0;
      transform:translateY(18px);
      animation:rise .7s ease forwards;
    }
    .delay-1{animation-delay:.08s}
    .delay-2{animation-delay:.18s}
    .delay-3{animation-delay:.28s}
    .delay-4{animation-delay:.38s}
    @keyframes rise{
      to{opacity:1;transform:translateY(0)}
    }
    @media (max-width: 980px){
      .hero-grid{
        grid-template-columns:1fr;
        gap:3rem;
      }
      .hero-copy{
        max-width:720px;
      }
    }
    @media (max-width: 700px){
      .nav-links{display:none}
      .image-frame::before{left:-12px;bottom:-12px}
      .image-frame::after{right:-8px;top:-8px}
    }
  </style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 </head>
