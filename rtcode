    :root{
      --ink:#0a0a0a;
      --bone:#f2efe7;
      --acid:#d8ff3e;
      --muted:#b9b7ae;
      --line:#2d2d2d;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:'DM Sans',sans-serif;
      color:var(--bone);
      background:#0a0a0a;
    }
    .display{font-family:'Oswald',sans-serif;text-transform:uppercase;letter-spacing:-0.04em}
    .fine-line{border-color:rgba(242,239,231,.16)}
    .hero-title{line-height:.88}
    .hero-title .stroke{
      color:transparent;
      -webkit-text-stroke:1.4px var(--bone);
    }
    .grain:before{
      content:"";
      position:absolute;inset:0;pointer-events:none;opacity:.08;
      background-image:radial-gradient(rgba(255,255,255,.9) .55px, transparent .55px);
      background-size:4px 4px;
      mix-blend-mode:screen;
    }
    .reveal{animation:rise .8s ease both}
    .reveal-2{animation:rise .8s .15s ease both}
    .reveal-3{animation:rise .8s .3s ease both}
    @keyframes rise{
      from{opacity:0;transform:translateY(24px)}
      to{opacity:1;transform:translateY(0)}
    }
    .card-image{transition:transform .7s ease}
    .program-card:hover .card-image{transform:scale(1.07)}
    .program-card:hover .program-arrow{transform:translateX(6px)}
    .program-arrow{transition:transform .25s ease}
    .nav-link{position:relative}
    .nav-link:after{
      content:"";position:absolute;left:0;bottom:-6px;width:0;height:1px;background:var(--acid);transition:width .25s ease;
    }
    .nav-link:hover:after{width:100%}
    .btn-focus:focus-visible,.nav-link:focus-visible{
      outline:2px solid var(--acid);outline-offset:4px;
    }
    .hero-photo:after{
      content:"";position:absolute;inset:0;
      background:linear-gradient(to top, rgba(10,10,10,.65), transparent 45%, rgba(10,10,10,.05));
    }
    .slash-bg{
      background:
        linear-gradient(115deg, transparent 0 62%, rgba(216,255,62,.08) 62% 67%, transparent 67%),
        #101010;
    }
  </style>
