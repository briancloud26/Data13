  <script src="/_sdk/editing_sdk.js"></script>
  <script>
    // Python keywords and builtins for highlighting and autocomplete
    const KEYWORDS = ['False','None','True','and','as','assert','async','await','break','class','continue','def','del','elif','else','except','finally','for','from','global','if','import','in','is','lambda','nonlocal','not','or','pass','raise','return','try','while','with','yield'];
    const BUILTINS = ['print','range','len','int','str','float','list','dict','set','tuple','type','input','open','map','filter','zip','enumerate','sorted','reversed','abs','sum','min','max','round','isinstance','hasattr','getattr','setattr','super','property','staticmethod','classmethod'];
    const ALL_WORDS = [...KEYWORDS, ...BUILTINS];

    // Syntax highlighting
    function highlight(code) {
      // Escape HTML
      let h = code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      // Comments
      h = h.replace(/(#[^\n]*)/g, '<span class="cmt">$1</span>');
      // Strings (simple - triple and single/double quotes)
      h = h.replace(/("""[\s\S]*?"""|'''[\s\S]*?'''|"(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')/g, '<span class="str">$1</span>');
      // Numbers
      h = h.replace(/\b(\d+\.?\d*)\b/g, '<span class="num">$1</span>');
      // Keywords
      const kwRe = new RegExp('\\b(' + KEYWORDS.join('|') + ')\\b', 'g');
      h = h.replace(kwRe, '<span class="kw">$1</span>');
      // Builtins
      const biRe = new RegExp('\\b(' + BUILTINS.join('|') + ')\\b', 'g');
      h = h.replace(biRe, '<span class="bi">$1</span>');
      // Function defs
      h = h.replace(/\b(def\s+)(\w+)/g, '$1<span class="fn">$2</span>');
      return h;
    }

    function updateHighlight() {
      const code = document.getElementById('code-editor').value;
      document.getElementById('highlight-layer').innerHTML = highlight(code) + '\n';
    }

    function updateLines() {
      const editor = document.getElementById('code-editor');
      const lines = editor.value.split('\n').length;
      document.getElementById('line-numbers').innerHTML = Array.from({length: lines}, (_, i) => `<div>${i + 1}</div>`).join('');
    }

    function syncScroll() {
      const ed = document.getElementById('code-editor');
      document.getElementById('line-numbers').scrollTop = ed.scrollTop;
      document.getElementById('highlight-layer').scrollTop = ed.scrollTop;
      document.getElementById('highlight-layer').scrollLeft = ed.scrollLeft;
    }

    function onEditorInput() {
      updateLines();
      updateHighlight();
      showAutocomplete();
    }

    updateLines();
    updateHighlight();

    // Autocomplete
    let acIndex = 0;
    let acItems = [];

    function getCurrentWord() {
      const ed = document.getElementById('code-editor');
      const pos = ed.selectionStart;
      const text = ed.value.substring(0, pos);
      const match = text.match(/[a-zA-Z_]\w*$/);
      return match ? match[0] : '';
    }

    function showAutocomplete() {
      const word = getCurrentWord();
      const ac = document.getElementById('autocomplete');
      if (word.length < 2) { ac.classList.add('hidden'); acItems = []; return; }
      acItems = ALL_WORDS.filter(w => w.startsWith(word) && w !== word).slice(0, 8);
      if (acItems.length === 0) { ac.classList.add('hidden'); return; }
      acIndex = 0;
      ac.innerHTML = acItems.map((item, i) => `<div class="${i === 0 ? 'active' : ''}" onmousedown="insertCompletion('${item}')">${item}</div>`).join('');
      // Position near caret
      const ed = document.getElementById('code-editor');
      const lines = ed.value.substring(0, ed.selectionStart).split('\n');
      const lineNum = lines.length - 1;
      const col = lines[lines.length - 1].length;
      ac.style.top = ((lineNum + 1) * 22.75 + 16) + 'px';
      ac.style.left = (col * 8.4 + 16) + 'px';
      ac.classList.remove('hidden');
    }

    function hideAutocomplete() {
      document.getElementById('autocomplete').classList.add('hidden');
      acItems = [];
    }

    function insertCompletion(word) {
      const ed = document.getElementById('code-editor');
      const pos = ed.selectionStart;
      const text = ed.value;
      const before = text.substring(0, pos);
      const currentWord = before.match(/[a-zA-Z_]\w*$/)[0];
      const insert = word.substring(currentWord.length);
      ed.value = text.substring(0, pos) + insert + text.substring(pos);
      ed.selectionStart = ed.selectionEnd = pos + insert.length;
      ed.focus();
      hideAutocomplete();
      onEditorInput();
    }

    function handleEditorKey(e) {
      if (e.key === 'Tab') {
        if (acItems.length > 0) { e.preventDefault(); insertCompletion(acItems[acIndex]); return; }
        e.preventDefault();
        const s = e.target.selectionStart, end = e.target.selectionEnd;
        e.target.value = e.target.value.substring(0, s) + '    ' + e.target.value.substring(end);
        e.target.selectionStart = e.target.selectionEnd = s + 4;
        onEditorInput();
      } else if (e.key === 'ArrowDown' && acItems.length > 0) {
        e.preventDefault();
        acIndex = Math.min(acIndex + 1, acItems.length - 1);
        renderAcActive();
      } else if (e.key === 'ArrowUp' && acItems.length > 0) {
        e.preventDefault();
        acIndex = Math.max(acIndex - 1, 0);
        renderAcActive();
      } else if (e.key === 'Enter' && acItems.length > 0) {
        e.preventDefault();
        insertCompletion(acItems[acIndex]);
      } else if (e.key === 'Escape') {
        hideAutocomplete();
      }
    }

    function renderAcActive() {
      const ac = document.getElementById('autocomplete');
      [...ac.children].forEach((el, i) => el.classList.toggle('active', i === acIndex));
    }

    // Theme
    function changeTheme(t) {
      document.body.className = document.body.className.replace(/theme-\w+/, `theme-${t}`);
      localStorage.setItem('py-theme', t);
    }
    const saved = localStorage.getItem('py-theme');
    if (saved) { changeTheme(saved); document.getElementById('theme-select').value = saved; }

    // Built-in snippets
    const BUILTIN_SNIPPETS = {
      'Hello World': 'print("Hello, World!")',
      'For Loop': 'for i in range(10):\n    print(i)',
      'Function': 'def greet(name):\n    return f"Hello, {name}!"\n\nprint(greet("World"))',
      'Class': 'class Animal:\n    def __init__(self, name):\n        self.name = name\n\n    def speak(self):\n        return f"{self.name} makes a sound"\n\ndog = Animal("Dog")\nprint(dog.speak())',
      'List Comprehension': 'squares = [x**2 for x in range(10)]\nprint(squares)',
      'Try/Except': 'try:\n    result = 10 / 0\nexcept ZeroDivisionError as e:\n    print(f"Error: {e}")\nfinally:\n    print("Done")',
      'Dictionary': 'person = {\n    "name": "Alice",\n    "age": 30,\n    "city": "NYC"\n}\n\nfor key, val in person.items():\n    print(f"{key}: {val}")',
      'Fibonacci': 'def fibonacci(n):\n    a, b = 0, 1\n    for _ in range(n):\n        print(a, end=" ")\n        a, b = b, a + b\n\nfibonacci(10)',
    };

    // Snippets panel
    function toggleSnippets() { document.getElementById('snippets-panel').classList.toggle('hidden'); }
    function saveSnippet() { document.getElementById('save-form').classList.remove('hidden'); document.getElementById('snippet-name-input').focus(); }
    function confirmSave(e) {
      e.preventDefault();
      const name = document.getElementById('snippet-name-input').value.trim();
      if (!name) return;
      const snippets = JSON.parse(localStorage.getItem('py-snippets') || '{}');
      snippets[name] = document.getElementById('code-editor').value;
      localStorage.setItem('py-snippets', JSON.stringify(snippets));
      document.getElementById('snippet-name-input').value = '';
      document.getElementById('save-form').classList.add('hidden');
      renderSnippets();
    }
    function loadSnippet(code) {
      document.getElementById('code-editor').value = code;
      onEditorInput();
    }
    function deleteSnippet(name) {
      const snippets = JSON.parse(localStorage.getItem('py-snippets') || '{}');
      delete snippets[name];
      localStorage.setItem('py-snippets', JSON.stringify(snippets));
      renderSnippets();
    }
    function renderSnippets() {
      const snippets = JSON.parse(localStorage.getItem('py-snippets') || '{}');
      const list = document.getElementById('snippets-list');
      let html = '';
      // Built-in
      html += '<p style="color:var(--gutter);font-size:0.65rem;padding:4px 4px 2px;text-transform:uppercase;">Built-in</p>';
      for (const [name, code] of Object.entries(BUILTIN_SNIPPETS)) {
        html += `<div class="snippet-item flex items-center justify-between px-2 py-1 rounded cursor-pointer" onclick="loadSnippet(BUILTIN_SNIPPETS['${name}'])"><span style="color:var(--fg);font-size:0.75rem;" class="truncate">${name}</span><span class="builtin-badge">built-in</span></div>`;
      }
      // User saved
      const userKeys = Object.keys(snippets);
      if (userKeys.length > 0) {
        html += '<p style="color:var(--gutter);font-size:0.65rem;padding:8px 4px 2px;text-transform:uppercase;">My Snippets</p>';
        for (const name of userKeys) {
          const safeName = name.replace(/'/g, "\\'");
          html += `<div class="snippet-item flex items-center justify-between px-2 py-1 rounded cursor-pointer" onclick="loadSnippet(JSON.parse(localStorage.getItem('py-snippets')||'{}')['${safeName}'])"><span style="color:var(--fg);font-size:0.75rem;" class="truncate">${name}</span><button onclick="event.stopPropagation();deleteSnippet('${safeName}')" style="color:var(--error);" class="ml-1 flex-shrink-0"><i data-lucide="trash-2" style="width:12px;height:12px;"></i></button></div>`;
        }
      }
      list.innerHTML = html;
      lucide.createIcons();
    }
    renderSnippets();

    // Run
    function runCode() {
      const code = document.getElementById('code-editor').value;
      const output = document.getElementById('output');
      output.textContent = '';
      output.classList.remove('error-text');
      Sk.configure({
        output: function(text) { output.textContent += text; },
        read: function(x) {
          if (Sk.builtinFiles === undefined || Sk.builtinFiles["files"][x] === undefined) throw "File not found: '" + x + "'";
          return Sk.builtinFiles["files"][x];
        }
      });
      Sk.misceval.asyncToPromise(function() {
        return Sk.importMainWithBody("<stdin>", false, code, true);
      }).catch(function(e) {
        output.classList.add('error-text');
        output.textContent = e.toString();
      });
    }

    lucide.createIcons();
  </script>
