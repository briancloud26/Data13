  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&amp;family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&amp;display=swap" rel="stylesheet">
  <style>
    :root{
      --ink:#25231f;
      --muted:#716d64;
      --paper:#f4f0e8;
      --paper-2:#ebe5da;
      --line:#d6cec1;
      --sage:#aeb9a3;
      --sage-dark:#6e7b67;
      --clay:#c7775f;
      --cream:#fbf8f2;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:'DM Sans', sans-serif;
      color:var(--ink);
      background:var(--paper);
    }

    .page-shell{
      width:100%;
      min-height:100%;
      background:
        radial-gradient(circle at 20% 12%, rgba(255,255,255,.55), transparent 25%),
        linear-gradient(135deg, rgba(255,255,255,.12) 0%, rgba(255,255,255,0) 48%),
        var(--paper);
    }

    .editorial{
      font-family:'Fraunces', serif;
      letter-spacing:-0.045em;
    }

    .hairline{
      border-color:var(--line);
    }

    .project-card:hover .project-image{
      transform:scale(1.035);
    }

    .project-card:hover .project-arrow{
      transform:translate(4px,-4px);
    }

    .project-image,
    .project-arrow{
      transition:all .45s cubic-bezier(.2,.65,.2,1);
    }

    .reveal{
      opacity:0;
      transform:translateY(18px);
      animation: riseIn .8s ease forwards;
    }

    .delay-1{animation-delay:.08s}
    .delay-2{animation-delay:.18s}
    .delay-3{animation-delay:.3s}
    .delay-4{animation-delay:.42s}

    @keyframes riseIn{
      to{opacity:1; transform:translateY(0)}
    }

    .focus-ring:focus-visible{
      outline:2px solid var(--clay);
      outline-offset:4px;
    }

    @media (max-width: 900px){
      .hero-grid{
        grid-template-columns:1fr !important;
      }
      .hero-visual{
        margin-top:2rem;
      }
      .work-grid{
        grid-template-columns:1fr !important;
      }
      .about-grid{
        grid-template-columns:1fr !important;
      }
    }
  </style>
