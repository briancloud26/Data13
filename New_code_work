<!doctype html>
<html lang="en"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Data Explorer Dashboard</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <style>
    :root{
      --ink:#0b1220;
      --panel:#111a2e;
      --panel-2:#15223a;
      --line:#23304b;
      --muted:#8fa0bd;
      --soft:#c9d4e7;
      --cyan:#66e3d0;
      --amber:#f6c66b;
      --rose:#f58f9d;
      --blue:#8db8ff;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:'DM Sans',sans-serif;
      background:#0b1220;
      color:#f5f7fb;
    }
    .mono{font-family:'Space Mono',monospace}
    .glass-line{
      background-image: linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(255,255,255,.02) 1px, transparent 1px);
      background-size: 36px 36px;
    }
    .metric-card{
      background:linear-gradient(180deg,rgba(255,255,255,.035),rgba(255,255,255,.015));
      border:1px solid var(--line);
    }
    .table-row:hover{
      background:rgba(141,184,255,.045);
    }
    .focus-ring:focus{
      outline:2px solid #66e3d0;
      outline-offset:2px;
    }
    select{
      appearance:none;
      background-image:linear-gradient(45deg, transparent 50%, #91a2bf 50%),linear-gradient(135deg, #91a2bf 50%, transparent 50%);
      background-position:calc(100% - 18px) 50%,calc(100% - 13px) 50%;
      background-size:5px 5px,5px 5px;
      background-repeat:no-repeat;
    }
  </style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
  <script src="/_sdk/resizing_sdk.js" type="text/javascript"></script>
 <script src="/_sdk/telemetry_sdk.js"></script></head>
 <body data-template-id="__page-root" class="w-full min-h-screen" style="background: rgb(11, 18, 32);">
  <div class="w-full min-h-screen glass-line">
   <header class="w-full border-b border-[#1e2940]">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-8">
     <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5">
      <div>
       <p data-template-id="eyebrow" class="canva-text mono uppercase tracking-[0.24em] text-xs mb-3" style="color: rgb(102, 227, 208); font-weight: 700; font-style: normal; font-size: 11px; letter-spacing: 0.18rem;">ANALYTICS WORKSPACE</p>
       <h1 data-template-id="dashboard-title" class="canva-text font-bold leading-tight mb-3" style="color: rgb(244, 247, 251); font-weight: 700; font-style: normal; font-size: 30px;">Data Explorer</h1>
       <p data-template-id="dashboard-subtitle" class="canva-text max-w-2xl" style="color: rgb(156, 174, 204); font-weight: 400; font-style: normal; font-size: 16px;">Search, filter, and inspect customer records without writing a single query.</p>
      </div>
      <div class="flex items-center">
       <div data-template-id="sample-badge" class="canva-tag inline-flex items-center gap-2 px-3 py-2 rounded-full border border-[#24483f] text-sm" style="background: rgb(16, 36, 31); color: rgb(174, 244, 233); font-weight: 500; font-style: normal; font-size: 13px;">Live sample dataset</div>
      </div>
     </div>
    </div>
   </header>
   <main class="max-w-[1400px] mx-auto px-6 lg:px-10 py-7">
    <section aria-label="Summary metrics" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-7">
     <article class="metric-card rounded-2xl p-5">
      <div class="flex items-center justify-between mb-4">
       <p data-template-id="metric-1-label" class="canva-text text-sm" style="color: rgb(146, 164, 194); font-weight: 500; font-style: normal; font-size: 13px;">Total Records</p><i data-lucide="database" class="w-4 h-4 text-[#66e3d0]"></i>
      </div>
      <div data-template-id="metric-1-value" class="canva-text mono text-3xl font-bold" style="color: rgb(244, 247, 251); font-weight: 700; font-style: normal; font-size: 30px;">10,248</div>
      <p class="text-xs text-[#70819f] mt-2">Across all customer records</p>
     </article>
     <article class="metric-card rounded-2xl p-5">
      <div class="flex items-center justify-between mb-4">
       <p data-template-id="metric-2-label" class="canva-text text-sm" style="color: rgb(146, 164, 194); font-weight: 500; font-style: normal; font-size: 13px;">Active Accounts</p><i data-lucide="activity" class="w-4 h-4 text-[#8db8ff]"></i>
      </div>
      <div data-template-id="metric-2-value" class="canva-text mono text-3xl font-bold" style="color: rgb(244, 247, 251); font-weight: 700; font-style: normal; font-size: 30px;">8,914</div>
      <p class="text-xs text-[#70819f] mt-2">Currently in good standing</p>
     </article>
     <article class="metric-card rounded-2xl p-5">
      <div class="flex items-center justify-between mb-4">
       <p data-template-id="metric-3-label" class="canva-text text-sm" style="color: rgb(146, 164, 194); font-weight: 500; font-style: normal; font-size: 13px;">Avg. Revenue</p><i data-lucide="bar-chart-3" class="w-4 h-4 text-[#f6c66b]"></i>
      </div>
      <div data-template-id="metric-3-value" class="canva-text mono text-3xl font-bold" style="color: rgb(244, 247, 251); font-weight: 700; font-style: normal; font-size: 30px;">$12.4k</div>
      <p class="text-xs text-[#70819f] mt-2">Monthly recurring revenue</p>
     </article>
     <article class="metric-card rounded-2xl p-5">
      <div class="flex items-center justify-between mb-4">
       <p data-template-id="metric-4-label" class="canva-text text-sm" style="color: rgb(146, 164, 194); font-weight: 500; font-style: normal; font-size: 13px;">At Risk</p><i data-lucide="triangle-alert" class="w-4 h-4 text-[#f58f9d]"></i>
      </div>
      <div data-template-id="metric-4-value" class="canva-text mono text-3xl font-bold" style="color: rgb(244, 247, 251); font-weight: 700; font-style: normal; font-size: 30px;">438</div>
      <p class="text-xs text-[#70819f] mt-2">Requires attention</p>
     </article>
    </section>
    <section data-template-id="explorer-panel" class="canva-panel rounded-3xl border border-[#22314d] bg-[#111a2e] overflow-hidden" style="background: rgb(17, 26, 46);">
     <div class="px-5 sm:px-6 lg:px-7 py-6 border-b border-[#22314d]">
      <div class="flex flex-col xl:flex-row xl:items-end xl:justify-between gap-5">
       <div>
        <h2 data-template-id="explorer-title" class="canva-text font-semibold mb-2" style="color: rgb(241, 245, 251); font-weight: 600; font-style: normal; font-size: 23px;">Customer records</h2>
        <p data-template-id="explorer-subtitle" class="canva-text text-sm" style="color: rgb(143, 160, 189); font-weight: 400; font-style: normal; font-size: 14px;">Use the controls below to narrow the dataset in real time.</p>
       </div>
       <div class="mono text-xs text-[#6f819f]">
        DATASET / CUSTOMER_HEALTH_V2
       </div>
      </div>
     </div>
     <form id="filter-form" class="px-5 sm:px-6 lg:px-7 py-5 border-b border-[#22314d]">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-[1.4fr_.8fr_.8fr_.8fr_auto] gap-4 items-end">
       <div><label data-template-id="search-label" for="search" class="canva-text block text-xs uppercase tracking-[0.16em] mb-2" style="color: rgb(127, 146, 176); font-weight: 700; font-style: normal; font-size: 10px; letter-spacing: 0.12rem;">Search</label>
        <div class="relative"><i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-[#7890b0]"></i> <input id="search" data-template-id="search-input" type="text" class="canva-input focus-ring w-full rounded-xl border border-[#2a3a59] bg-[#0d1628] text-[#eef4ff] placeholder:text-[#667895] pl-10 pr-3 py-3 text-sm" placeholder="Search customers, companies, regions..." style="color: rgb(238, 244, 255); font-weight: 400; font-style: normal; font-size: 14px;">
        </div>
       </div>
       <div><label data-template-id="status-label" for="status-filter" class="canva-text block text-xs uppercase tracking-[0.16em] mb-2" style="color: rgb(127, 146, 176); font-weight: 700; font-style: normal; font-size: 10px; letter-spacing: 0.12rem;">Status</label> <select id="status-filter" class="focus-ring w-full rounded-xl border border-[#2a3a59] bg-[#0d1628] text-[#dce6f6] px-3 py-3 text-sm"> <option value="all">All statuses</option> <option value="Active">Active</option> <option value="At Risk">At Risk</option> <option value="Paused">Paused</option> </select>
       </div>
       <div><label data-template-id="plan-label" for="plan-filter" class="canva-text block text-xs uppercase tracking-[0.16em] mb-2" style="color: rgb(127, 146, 176); font-weight: 700; font-style: normal; font-size: 10px; letter-spacing: 0.12rem;">Plan</label> <select id="plan-filter" class="focus-ring w-full rounded-xl border border-[#2a3a59] bg-[#0d1628] text-[#dce6f6] px-3 py-3 text-sm"> <option value="all">All plans</option> <option value="Enterprise">Enterprise</option> <option value="Growth">Growth</option> <option value="Starter">Starter</option> </select>
       </div>
       <div><label data-template-id="region-label" for="region-filter" class="canva-text block text-xs uppercase tracking-[0.16em] mb-2" style="color: rgb(127, 146, 176); font-weight: 700; font-style: normal; font-size: 10px; letter-spacing: 0.12rem;">Region</label> <select id="region-filter" class="focus-ring w-full rounded-xl border border-[#2a3a59] bg-[#0d1628] text-[#dce6f6] px-3 py-3 text-sm"> <option value="all">All regions</option> <option value="North America">North America</option> <option value="Europe">Europe</option> <option value="APAC">APAC</option> <option value="LATAM">LATAM</option> </select>
       </div><button data-template-id="reset-button" type="button" id="reset-button" class="canva-button focus-ring rounded-xl px-4 py-3 text-sm font-medium border border-[#315a52] bg-[#14352f] text-[#bdf7ec] hover:bg-[#19443d] transition" style="background: rgb(20, 53, 47); color: rgb(189, 247, 236); font-weight: 500; font-style: normal; font-size: 14px;">Reset filters</button>
      </div>
     </form>
     <div class="px-5 sm:px-6 lg:px-7 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-b border-[#22314d]">
      <div class="flex items-center gap-2"><span data-template-id="results-label" class="canva-text text-sm" style="color: rgb(150, 168, 196); font-weight: 400; font-style: normal; font-size: 14px;">Showing</span> <span id="result-count" class="mono text-sm text-[#66e3d0]"></span>
      </div>
      <div class="flex items-center gap-3"><label data-template-id="sort-label" for="sort-select" class="canva-text text-xs uppercase tracking-[0.14em]" style="color: rgb(116, 134, 164); font-weight: 700; font-style: normal; font-size: 10px; letter-spacing: 0.12rem;">Sort by</label> <select id="sort-select" class="focus-ring rounded-lg border border-[#2a3a59] bg-[#0d1628] text-[#dce6f6] px-3 py-2 text-sm min-w-[180px]"> <option value="revenue-desc">Revenue: high to low</option> <option value="revenue-asc">Revenue: low to high</option> <option value="name-asc">Customer: A–Z</option> <option value="joined-desc">Newest joined</option> </select>
      </div>
     </div>
     <div class="overflow-x-auto">
      <table class="w-full min-w-[900px]">
       <thead>
        <tr class="border-b border-[#22314d] text-left">
         <th class="mono text-[11px] uppercase tracking-[0.16em] text-[#7183a2] font-normal px-7 py-4">Customer</th>
         <th class="mono text-[11px] uppercase tracking-[0.16em] text-[#7183a2] font-normal px-4 py-4">Company</th>
         <th class="mono text-[11px] uppercase tracking-[0.16em] text-[#7183a2] font-normal px-4 py-4">Plan</th>
         <th class="mono text-[11px] uppercase tracking-[0.16em] text-[#7183a2] font-normal px-4 py-4">Region</th>
         <th class="mono text-[11px] uppercase tracking-[0.16em] text-[#7183a2] font-normal px-4 py-4">Revenue</th>
         <th class="mono text-[11px] uppercase tracking-[0.16em] text-[#7183a2] font-normal px-4 py-4">Status</th>
        </tr>
       </thead>
       <tbody id="table-body"></tbody>
      </table>
     </div>
     <div id="empty-state" class="hidden px-6 py-14 text-center">
      <div class="w-12 h-12 mx-auto mb-4 rounded-2xl bg-[#18263e] flex items-center justify-center text-[#7890b0]"><i data-lucide="search-x" class="w-5 h-5"></i>
      </div>
      <p data-template-id="empty-state" class="canva-text" style="color: rgb(143, 160, 189); font-weight: 400; font-style: normal; font-size: 14px;">No matching records. Try adjusting your filters.</p>
     </div>
    </section>
   </main>
  </div>
  <script src="/_sdk/editing_sdk.js"></script>
  <script>
    const rows = [
      { name:"Maya Chen", email:"maya@northstar.io", company:"Northstar Labs", plan:"Enterprise", region:"North America", revenue:18400, status:"Active", joined:"2025-12-14" },
      { name:"Jon Bell", email:"jon@kinship.co", company:"Kinship Co.", plan:"Growth", region:"Europe", revenue:9200, status:"Active", joined:"2025-11-02" },
      { name:"Amara Okafor", email:"amara@stridehq.com", company:"Stride HQ", plan:"Enterprise", region:"Europe", revenue:16100, status:"At Risk", joined:"2025-09-21" },
      { name:"Leo Martinez", email:"leo@bravoworks.mx", company:"Bravo Works", plan:"Starter", region:"LATAM", revenue:2800, status:"Paused", joined:"2025-08-18" },
      { name:"Sofia Reed", email:"sofia@clearbit.studio", company:"Clearbit Studio", plan:"Growth", region:"North America", revenue:7400, status:"Active", joined:"2026-01-11" },
      { name:"Noah Tan", email:"noah@orbitlane.sg", company:"Orbitlane", plan:"Enterprise", region:"APAC", revenue:21200, status:"Active", joined:"2025-10-05" },
      { name:"Iris Walsh", email:"iris@fablegrid.com", company:"Fablegrid", plan:"Starter", region:"Europe", revenue:3400, status:"At Risk", joined:"2025-07-29" },
      { name:"Ethan Brooks", email:"ethan@signalpeak.us", company:"Signal Peak", plan:"Growth", region:"North America", revenue:8100, status:"Active", joined:"2026-02-04" },
      { name:"Nina Patel", email:"nina@atlasloom.in", company:"Atlas Loom", plan:"Growth", region:"APAC", revenue:6800, status:"Paused", joined:"2025-06-16" },
      { name:"Mateo Silva", email:"mateo@cobaltflow.br", company:"Cobalt Flow", plan:"Enterprise", region:"LATAM", revenue:14900, status:"Active", joined:"2025-12-28" },
      { name:"Luttu", email:"luttu@luttuworks.io", company:"Luttu Works", plan:"Growth", region:"APAC", revenue:5900, status:"Active", joined:"2026-03-12" }
    ];

    const tableBody = document.getElementById('table-body');
    const resultCount = document.getElementById('result-count');
    const emptyState = document.getElementById('empty-state');
    const search = document.getElementById('search');
    const statusFilter = document.getElementById('status-filter');
    const planFilter = document.getElementById('plan-filter');
    const regionFilter = document.getElementById('region-filter');
    const sortSelect = document.getElementById('sort-select');
    const resetButton = document.getElementById('reset-button');

    document.getElementById('filter-form').addEventListener('submit', e => e.preventDefault());

    function statusClass(status){
      if(status === 'Active') return 'bg-[#133a32] text-[#8af0df] border-[#235e52]';
      if(status === 'At Risk') return 'bg-[#43252b] text-[#ffb4bf] border-[#6a3942]';
      return 'bg-[#3c3320] text-[#f5d58a] border-[#695635]';
    }

    function planClass(plan){
      if(plan === 'Enterprise') return 'text-[#9ec2ff]';
      if(plan === 'Growth') return 'text-[#8ce8d9]';
      return 'text-[#d2d9e8]';
    }

    function initials(name){
      return name.split(' ').map(n => n[0]).join('');
    }

    function formatMoney(value){
      return '$' + value.toLocaleString('en-US');
    }

    function getFilteredRows(){
      const query = search.value.trim().toLowerCase();
      const status = statusFilter.value;
      const plan = planFilter.value;
      const region = regionFilter.value;

      let filtered = rows.filter(row => {
        const matchesQuery = !query || [row.name, row.email, row.company, row.region].some(v => v.toLowerCase().includes(query));
        const matchesStatus = status === 'all' || row.status === status;
        const matchesPlan = plan === 'all' || row.plan === plan;
        const matchesRegion = region === 'all' || row.region === region;
        return matchesQuery && matchesStatus && matchesPlan && matchesRegion;
      });

      switch(sortSelect.value){
        case 'revenue-asc':
          filtered.sort((a,b) => a.revenue - b.revenue);
          break;
        case 'name-asc':
          filtered.sort((a,b) => a.name.localeCompare(b.name));
          break;
        case 'joined-desc':
          filtered.sort((a,b) => new Date(b.joined) - new Date(a.joined));
          break;
        default:
          filtered.sort((a,b) => b.revenue - a.revenue);
      }
      return filtered;
    }

    function render(){
      const filtered = getFilteredRows();
      tableBody.innerHTML = '';

      filtered.forEach(row => {
        const tr = document.createElement('tr');
        tr.className = 'table-row border-b border-[#1d2940] transition';
        tr.innerHTML = `
          <td class="px-7 py-4">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-[#1b2a45] border border-[#2c3e61] text-[#bad1f6] flex items-center justify-center text-xs font-semibold">${initials(row.name)}</div>
              <div>
                <div class="text-sm font-medium text-[#eef4ff]">${row.name}</div>
                <div class="text-xs text-[#7386a6] mt-0.5">${row.email}</div>
              </div>
            </div>
          </td>
          <td class="px-4 py-4 text-sm text-[#c8d4e7]">${row.company}</td>
          <td class="px-4 py-4 text-sm font-medium ${planClass(row.plan)}">${row.plan}</td>
          <td class="px-4 py-4 text-sm text-[#aebdd4]">${row.region}</td>
          <td class="px-4 py-4 mono text-sm text-[#ecf3ff]">${formatMoney(row.revenue)}</td>
          <td class="px-4 py-4">
            <span class="inline-flex items-center px-2.5 py-1 rounded-full border text-xs ${statusClass(row.status)}">${row.status}</span>
          </td>
        `;
        tableBody.appendChild(tr);
      });

      resultCount.textContent = `${filtered.length} records`;
      emptyState.classList.toggle('hidden', filtered.length !== 0);
    }

    [search, statusFilter, planFilter, regionFilter, sortSelect].forEach(el => {
      el.addEventListener('input', render);
      el.addEventListener('change', render);
    });

    resetButton.addEventListener('click', () => {
      search.value = '';
      statusFilter.value = 'all';
      planFilter.value = 'all';
      regionFilter.value = 'all';
      sortSelect.value = 'revenue-desc';
      render();
      search.focus();
    });

    render();
    lucide.createIcons();
  </script>
